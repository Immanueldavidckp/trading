# Copy this file to `.env` and fill in your own credentials.
# `.env` is gitignored — never commit real secrets.

# --- Shoonya (Finvasia) API ---
# Get from: https://shoonya.com -> Profile -> API key
SHOONYA_USER_ID=
SHOONYA_PASSWORD=
SHOONYA_VENDOR_CODE=
SHOONYA_API_KEY=
# BASE32 seed of your 2FA (NOT the 6-digit OTP code)
SHOONYA_TOTP_SECRET=
SHOONYA_IMEI=abc1234

# --- Google Gemini (optional, for AI analysis) ---
# Get free key at: https://aistudio.google.com/app/apikey
# Leave blank to use the built-in rule-based engine.
GEMINI_API_KEY=

# --- Upstox API (free with Upstox demat account) ---
# Steps:
#   1. Go to https://developer.upstox.com/developer/apps
#   2. Create New App → set Redirect URL:
#        LOCAL:  http://127.0.0.1:8000/api/upstox/callback
#        SERVER: http://api.mtandtiot.in:8000/api/upstox/callback
#   3. Copy the API Key and API Secret below
#   4. Open /api/upstox/login_url in browser → login → token saved automatically (repeat daily)
# NOTE: On server the UPSTOX_REDIRECT_URI is written automatically by the deploy workflow.
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://127.0.0.1:8000/api/upstox/callback

# --- Upstox automated daily login (optional, via the upstox-totp package) ---
# Lets the server log in by itself each morning (token expires daily ~3:30 AM IST).
# Upstox login is passwordless: mobile + TOTP + PIN.
#   UPSTOX_USERNAME    = 10-digit registered mobile number
#   UPSTOX_PIN_CODE    = 6-digit login PIN
#   UPSTOX_TOTP_SECRET = TOTP secret seed (base32) from Upstox -> Profile -> TOTP
# A server crontab hits /api/upstox/autologin at ~8:30 AM IST Mon-Fri.
UPSTOX_USERNAME=
UPSTOX_PIN_CODE=
UPSTOX_TOTP_SECRET=

# --- Trading mode ---
# true  = paper / mock (safe)
# false = LIVE with REAL money
MOCK_MODE=true
